{
  "name": "verdict-arena",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "deploy:contract": "node ./deploy/deploy-contract.mjs",
    "deploy:bind:modes": "node ./deploy/bind-mode-contracts.mjs",
    "deploy:upgrade": "node ./deploy/upgrade-contract.mjs",
    "deploy:smoke:c2c": "node ./deploy/smoke-contract-to-contract.mjs",
    "loadtest:studionet": "node ./scripts/studionet-loadtest.mjs",
    "relayer": "node ./deploy/relayer.mjs",
    "compile:evm": "hardhat compile --config hardhat.config.cjs",
    "deploy:profile:nft": "hardhat run deploy/deploy-profile-nft.cjs --network baseSepolia --config hardhat.config.cjs",
    "deploy:profile:nft:operator": "hardhat run deploy/set-profile-nft-operator.cjs --network baseSepolia --config hardhat.config.cjs",
    "deploy:profile:rewarders": "hardhat run deploy/set-profile-rewarders.cjs --network baseSepolia --config hardhat.config.cjs",
    "contract:test": ".\\.venv\\Scripts\\python -m pytest tests/direct -v",
    "test": "vitest run",
    "test:watch": "vitest"
  },
