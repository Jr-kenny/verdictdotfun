# Credit vault (sub-project #1, Plan 1A).
CREDIT_VAULT_OWNER=
CREDIT_VAULT_BRIDGE=
CREDIT_VAULT_USDC=

# Credit bridge (sub-project #1, Plan 1D). The bridge key must equal the vault
